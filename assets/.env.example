# Research Supercharged — Build (SDK) rail environment
# Copy to `.env` and fill in. Auth uses DefaultAzureCredential, so run `az login` first.

# The shared workshop project endpoint (Foundry portal -> project -> Overview -> Endpoint).
FOUNDRY_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>

# Teaching model deployment. model-router picks a good model automatically so no one stalls.
FOUNDRY_MODEL_NAME=model-router

# Web Search (Lab 1) works on model-router — no change needed. To pin a specific Azure OpenAI
# model as a fallback, uncomment the next line (requires that deployment in the project).
# FOUNDRY_WEBSEARCH_MODEL=gpt-4.1

# Your initials -> agents are named rc-<initials> so the shared project stays tidy.
INITIALS=xx
